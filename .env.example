# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Redis — local: docker compose up -d  →  redis://127.0.0.1:6379
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# -----------------------------------------------------------------------------
# Thirdweb — backend signer / contract calls (never expose in client bundles)
# -----------------------------------------------------------------------------
THIRDWEB_PRIVATE_KEY=0xYourWalletPrivateKeyForServerSideOperations

# -----------------------------------------------------------------------------
# Crossmint — placeholder: Bearer or X-Webhook-Secret; replace with official
# signature verification when Crossmint provides signing keys/docs.
# -----------------------------------------------------------------------------
CROSSMINT_WEBHOOK_SECRET=your-crossmint-webhook-signing-secret

# -----------------------------------------------------------------------------
# Optional: chain RPC (Alchemy, Infura, etc.)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CHAIN_ID=84532
# ALCHEMY_API_KEY=your-alchemy-key
